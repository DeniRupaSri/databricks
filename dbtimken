{
  "name": "predictive_pricing_model_pipeline",
  "email_notifications": {
    "no_alert_for_skipped_runs": false
  },
  "webhook_notifications": {},
  "timeout_seconds": 0,
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "Training_Data_No_Year",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Predictive Pricing PoC/SNP/Training_Without_Year_NB",
        "source": "WORKSPACE"
      },
      "existing_cluster_id": "0304-124731-6m89rqn6",
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Metric_Comparison",
      "depends_on": [
        {
          "task_key": "Training_Data_No_Year"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Predictive Pricing PoC/SNP/Metric_Comaparison_NB",
        "source": "WORKSPACE"
      },
      "existing_cluster_id": "0304-124731-6m89rqn6",
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Check_Model_Improvement",
      "depends_on": [
        {
          "task_key": "Metric_Comparison"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "condition_task": {
        "op": "EQUAL_TO",
        "left": "{{tasks.Metric_Comparison.values.register_model}}",
        "right": "yes"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Model_Register",
      "depends_on": [
        {
          "task_key": "Check_Model_Improvement",
          "outcome": "true"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Predictive Pricing PoC/SNP/ModelRegister_Without_Year_NB",
        "source": "WORKSPACE"
      },
      "existing_cluster_id": "0304-124731-6m89rqn6",
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Predictive_Pricing_endpoint_pl",
      "depends_on": [
        {
          "task_key": "Model_Register"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "run_job_task": {
        "job_id": 403854339099717
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Model_Alert",
      "depends_on": [
        {
          "task_key": "Check_Model_Improvement",
          "outcome": "false"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Predictive Pricing PoC/SNP/Model_Not_Improved_Alert_NB",
        "source": "WORKSPACE"
      },
      "existing_cluster_id": "0304-124731-6m89rqn6",
      "timeout_seconds": 0,
      "email_notifications": {
        "on_success": [
          "deni.lakamsani@snp.com"
        ]
      },
      "notification_settings": {
        "no_alert_for_skipped_runs": false,
        "no_alert_for_canceled_runs": false,
        "alert_on_last_attempt": false
      },
      "webhook_notifications": {},
      "disabled": false
    }
  ],
  "queue": {
    "enabled": true
  },
  "parameters": [
    {
      "name": "experiment_name",
      "default": "/Workspace/Predictive Pricing PoC/SNP/SRB_Predictive_Pricing_NoYear"
    },
    {
      "name": "model_name",
      "default": "predictivepricingpoc.default.gb_price_no_year"
    }
  ],
  "performance_target": "PERFORMANCE_OPTIMIZED"
}
